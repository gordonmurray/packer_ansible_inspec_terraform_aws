# Copy to terraform.tfvars and fill in.

# Your AWS account ID (the owner of the AMI built by Packer)
aws_account_id = ""

# EC2 instance type
default_instance_type = "t2.nano"

# Region is optional; defaults to eu-west-1 (or set AWS_REGION)
# region = "eu-west-1"

# Public key for the EC2 key pair; defaults to ~/.ssh/id_rsa.pub
# ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Optional: open SSH (port 22) to this CIDR only. Empty means no SSH rule.
# ssh_cidr = "203.0.113.4/32"
